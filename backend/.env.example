DATABASE_URL="postgresql://ucms:ucms@localhost:5432/ucms?schema=public"
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
PORT=3000
CORS_ORIGINS="http://localhost:3001"

# Redis / BullMQ (queue.module.ts)
REDIS_URL="redis://localhost:6379"

# S3-compatible object storage (storage.module.ts) — works with AWS S3,
# MinIO, DigitalOcean Spaces, etc.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_BUCKET="ucms-dev"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_FORCE_PATH_STYLE="true"

# Outbound email (notifications.processor.ts) — omit entirely to keep the
# documented log-only stub (no real send, Notification rows still marked
# "sent"). Set SMTP_HOST to switch on real delivery via any standard SMTP
# provider (Gmail, SES SMTP, SendGrid SMTP, Mailgun, a church mail server...).
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_SECURE="false"
# SMTP_USER="apikey"
# SMTP_PASSWORD="change-me"
# SMTP_FROM="no-reply@yourchurch.org"
