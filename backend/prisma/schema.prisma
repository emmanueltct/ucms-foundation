// ============================================================================
// UCMS - Foundation Module Prisma Schema
// Multi-tenancy, Auth (RBAC/PBAC), and the Configuration Engine
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// TENANT
// ----------------------------------------------------------------------------
model Tenant {
  id               String    @id @default(uuid())
  name             String
  slug             String    @unique
  customDomain     String?   @unique @map("custom_domain")
  logoUrl          String?   @map("logo_url")
  themeConfig      Json?     @map("theme_config")
  currency         String    @default("RWF")
  language         String    @default("en")
  timezone         String    @default("Africa/Kigali")
  subscriptionPlan String    @default("free") @map("subscription_plan")
  isActive         Boolean   @default(true) @map("is_active")
  onboardedAt      DateTime? @map("onboarded_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  users          User[]
  roles          Role[]
  configItems    ConfigItem[]
  featureToggles FeatureToggle[]
  refreshTokens  RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogs      AuditLog[]
  branches           Branch[]
  members            Member[]
  families           Family[]
  contributions      Contribution[]
  attendanceRecords  AttendanceRecord[]
  ministries         Ministry[]
  ministryMemberships MinistryMembership[]
  notifications      Notification[]
  customFieldDefinitions CustomFieldDefinition[]
  customFieldValues      CustomFieldValue[]
  events                 Event[]
  eventRegistrations     EventRegistration[]
  staff                  Staff[]
  payrollPayments        PayrollPayment[]
  assets                 Asset[]
  visitors               Visitor[]
  visitorGroups          VisitorGroup[]
  visitorActivities      VisitorActivity[]
  memberActivities       MemberActivity[]
  documents              Document[]
  documentVersions       DocumentVersion[]
  smallGroups            SmallGroup[]
  smallGroupMemberships  SmallGroupMembership[]
  approvalWorkflows      ApprovalWorkflow[]
  approvalSteps          ApprovalStep[]
  approvalRequests       ApprovalRequest[]
  deadlines              Deadline[]
  hierarchyRequirements  HierarchyRequirement[]
  hierarchyRequirementSubmissions HierarchyRequirementSubmission[]
  dynamicModuleDefinitions DynamicModuleDefinition[]
  dynamicModuleRecords   DynamicModuleRecord[]
  dynamicModuleRecordStatusHistory DynamicModuleRecordStatusHistory[]
  entityMemberships      EntityMembership[]

  @@map("tenants")
}

// ----------------------------------------------------------------------------
// PLATFORM ADMIN
// ----------------------------------------------------------------------------
/// Deliberately NOT a tenant-scoped model and NOT related to `User` — a
/// platform admin manages tenants themselves (see TenantsController), not
/// anything inside one, so it lives entirely outside the tenant-scoping
/// Prisma extension (see tenant-scoping.extension.ts's TENANT_SCOPED_MODELS,
/// which this is intentionally absent from) and authenticates through its
/// own login endpoint (PlatformAuthController) rather than AuthService.
model PlatformAdmin {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("platform_admins")
}

// ----------------------------------------------------------------------------
// USERS
// ----------------------------------------------------------------------------
model User {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  email        String
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  isActive     Boolean   @default(true) @map("is_active")
  mfaEnabled   Boolean   @default(false) @map("mfa_enabled")
  mfaSecret    String?   @map("mfa_secret")
  emailVerifiedAt DateTime? @map("email_verified_at")
  lastLoginAt  DateTime? @map("last_login_at")
  /// Which branch/level this user is assigned to for organizational-visibility
  /// roll-up (see BranchScopeService) — null means unrestricted (church-wide
  /// staff/admin), the default and the only behavior for every tenant that
  /// doesn't opt into per-branch user assignment, so existing single-branch
  /// or flat churches are entirely unaffected.
  assignedBranchId String? @map("assigned_branch_id")
  assignedBranch   Branch? @relation("UserAssignedBranch", fields: [assignedBranchId], references: [id])
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  userRoles             UserRole[]
  refreshTokens         RefreshToken[]
  passwordResetTokens   PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogs             AuditLog[]
  recordedContributions Contribution[]     @relation("ContributionRecordedBy")
  voidedContributions   Contribution[]     @relation("ContributionVoidedBy")
  recordedAttendance    AttendanceRecord[] @relation("AttendanceRecordedBy")
  createdNotifications  Notification[]     @relation("NotificationCreatedBy")
  paidPayrollPayments     PayrollPayment[] @relation("PayrollPaymentPaidBy")
  cancelledPayrollPayments PayrollPayment[] @relation("PayrollPaymentCancelledBy")
  assignedVisitors        Visitor[]        @relation("VisitorAssignedTo")
  assignedVisitorGroups   VisitorGroup[]   @relation("VisitorGroupAssignedTo")
  performedVisitorActivities VisitorActivity[] @relation("VisitorActivityPerformedBy")
  performedMemberActivities MemberActivity[] @relation("MemberActivityPerformedBy")
  uploadedDocuments       Document[]       @relation("DocumentUploadedBy")
  replacedDocumentVersions DocumentVersion[] @relation("DocumentVersionReplacedBy")
  extendedDeadlines       Deadline[]       @relation("DeadlineExtendedBy")
  submittedHierarchyRequirements HierarchyRequirementSubmission[]
  createdDynamicModuleRecords DynamicModuleRecord[] @relation("DynamicModuleRecordCreatedBy")
  changedDynamicModuleRecordStatuses DynamicModuleRecordStatusHistory[] @relation("DynamicModuleRecordStatusChangedBy")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ----------------------------------------------------------------------------
// ROLES / PERMISSIONS (RBAC + PBAC)
// ----------------------------------------------------------------------------
model Role {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

/// Global, platform-versioned catalog of permission codes.
/// New modules add rows here via migration; tenants only ever attach
/// existing codes to their own roles. The one deliberate exception:
/// DynamicModuleDefinitionsService programmatically appends
/// `dynamicmodule.{definitionId}.{action}` codes when an admin builds a new
/// module in the UI, since a UI-built module has no migration to add them
/// in — see docs/dynamic-modules/business-analysis.md.
model Permission {
  id          String  @id @default(uuid())
  code        String  @unique // e.g. "finance.contribution.create"
  module      String // e.g. "finance"
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String     @map("role_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ----------------------------------------------------------------------------
// AUTH SESSIONS
// ----------------------------------------------------------------------------
/// Each row is one "device session" — issued at login/switch-tenant, rotated
/// (old revoked, `replacedBy` set) on every `/auth/refresh` call, so the
/// same continuous session carries its `userAgent`/`ipAddress` forward
/// across rotations. `GET /auth/sessions` lists a user's active (non-revoked,
/// non-expired) rows as their signed-in devices; `DELETE /auth/sessions/:id`
/// revokes one without needing the token itself, the way `logout` does.
model RefreshToken {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id])
  tokenHash  String    @map("token_hash")
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  replacedBy String?   @map("replaced_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([tenantId])
  @@map("refresh_tokens")
}

/// A one-time-use token for the forgot/reset-password flow. Looked up by
/// `tokenHash` alone (never by tenantId — the tenant is resolved *from* the
/// token, via `PrismaService.unscoped`, exactly like login-by-email
/// routing does), since the person resetting their password doesn't
/// necessarily know or remember which church workspace they're in.
model PasswordResetToken {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([userId])
  @@map("password_reset_tokens")
}

/// A one-time-use token confirming a user's email address on registration.
/// Mirrors PasswordResetToken's shape exactly (separate table rather than
/// a shared generic one, since the two purposes have no fields in common
/// beyond "a hashed token with an expiry" and keeping them separate means
/// a bug in one flow's queries can't touch the other's rows).
model EmailVerificationToken {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([userId])
  @@map("email_verification_tokens")
}

// ----------------------------------------------------------------------------
// CONFIGURATION ENGINE (generic — powers ministries, contribution types,
// ceremony names, membership categories, etc. for every future module)
// ----------------------------------------------------------------------------
model ConfigItem {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  namespace String // "ministry" | "contribution_type" | "ceremony" | "membership_category" | ...
  key       String // stable machine key, e.g. "tithe"
  label     String // human display label, e.g. "Tithe"
  value     Json // arbitrary shape, owned by the consuming module
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, namespace, key])
  @@index([tenantId, namespace])
  @@map("config_items")
}

model FeatureToggle {
  id         String  @id @default(uuid())
  tenantId   String  @map("tenant_id")
  tenant     Tenant  @relation(fields: [tenantId], references: [id])
  featureKey String  @map("feature_key")
  isEnabled  Boolean @default(false) @map("is_enabled")

  @@unique([tenantId, featureKey])
  @@map("feature_toggles")
}

// ----------------------------------------------------------------------------
// CHURCH & HIERARCHY MANAGEMENT
// ----------------------------------------------------------------------------

/// A tenant's organizational hierarchy, modeled as a single self-referencing
/// tree of arbitrary depth so it can represent anything from a Catholic
/// diocese -> parish -> branch structure to a flat, single-location
/// independent church. Denomination-specific labels ("Diocese", "Parish",
/// "District", "Cell") are NOT modeled as an enum here — `branchType` is a
/// free-form key that a tenant defines via the Configuration Engine
/// (ConfigItem, namespace "branch_type"), consistent with the Foundation
/// module's rule that new "types" belong in the config engine, not a schema
/// change.
model Branch {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  parentBranchId String?   @map("parent_branch_id")
  parentBranch   Branch?   @relation("BranchHierarchy", fields: [parentBranchId], references: [id])
  childBranches  Branch[]  @relation("BranchHierarchy")
  name           String
  branchType     String?   @map("branch_type") // e.g. "parish", "district" — a ConfigItem key in namespace "branch_type"
  code           String?
  address        String?
  isHeadquarters Boolean   @default(false) @map("is_headquarters")
  isActive       Boolean   @default(true) @map("is_active")
  sortOrder      Int       @default(0) @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  members           Member[]
  contributions     Contribution[]
  attendanceRecords AttendanceRecord[]
  ministries        Ministry[]
  events            Event[]
  staff             Staff[]
  assets            Asset[]
  visitors          Visitor[]
  visitorGroups     VisitorGroup[]
  documents         Document[]
  smallGroups       SmallGroup[]
  assignedUsers     User[]             @relation("UserAssignedBranch")
  hierarchyRequirementSubmissions HierarchyRequirementSubmission[]
  dynamicModuleRecords DynamicModuleRecord[]

  @@index([tenantId])
  @@index([tenantId, parentBranchId])
  @@map("branches")
}

// ----------------------------------------------------------------------------
// MEMBER & FAMILY MANAGEMENT
// ----------------------------------------------------------------------------

/// A household grouping members together. Flat (no self-reference, unlike
/// Branch) — a family is a label members point to, not a hierarchy. See
/// docs/member-management/business-analysis.md for why deactivating a family
/// intentionally does NOT cascade to its members (contrast with Branch).
model Family {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  name           String
  address        String?
  phone          String?
  headOfFamilyId String?   @unique @map("head_of_family_id")
  headOfFamily   Member?   @relation("FamilyHead", fields: [headOfFamilyId], references: [id])
  notes          String?
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  members Member[] @relation("FamilyMembers")

  @@index([tenantId])
  @@map("families")
}

/// A person's membership profile, attached to exactly one Branch (Module 1)
/// and optionally grouped into a Family. `membershipCategory` is a free-form
/// ConfigItem key (namespace "membership_category") per the Foundation
/// module's "new types belong in the Configuration Engine" rule;
/// `membershipStatus` is a small fixed lifecycle enum instead, since later
/// modules (Attendance, Finance) reason structurally about it.
model Member {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  tenant             Tenant    @relation(fields: [tenantId], references: [id])
  branchId           String    @map("branch_id")
  branch             Branch    @relation(fields: [branchId], references: [id])
  familyId           String?   @map("family_id")
  family             Family?   @relation("FamilyMembers", fields: [familyId], references: [id])
  familyRole         String?   @map("family_role") // "head" | "spouse" | "child" | "dependent" | "other"
  membershipNumber   String?   @map("membership_number")
  firstName          String    @map("first_name")
  lastName           String    @map("last_name")
  gender             String?
  dateOfBirth        DateTime? @map("date_of_birth")
  phone              String?
  email              String?
  address            String?
  maritalStatus      String?   @map("marital_status")
  membershipCategory String?   @map("membership_category") // ConfigItem key, namespace "membership_category"
  membershipStatus   String    @default("active") @map("membership_status") // "active" | "inactive" | "transferred" | "deceased"
  joinedAt           DateTime? @map("joined_at")
  baptismDate        DateTime? @map("baptism_date")
  photoUrl           String?   @map("photo_url")
  notes              String?
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  headOfFamilyFor     Family?              @relation("FamilyHead")
  contributions       Contribution[]
  attendanceRecords   AttendanceRecord[]
  ministryMemberships MinistryMembership[]
  notifications       Notification[]
  eventRegistrations  EventRegistration[]
  staffRecord         Staff?
  invitedVisitors     Visitor[]            @relation("VisitorInvitedBy")
  convertedFromVisitor Visitor?            @relation("VisitorConvertedTo")
  smallGroupMemberships SmallGroupMembership[]
  memberActivities     MemberActivity[]
  entityMemberships    EntityMembership[]

  @@unique([tenantId, membershipNumber])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, familyId])
  @@map("members")
}

/// One logged, tenant-configurable activity against a Member that isn't
/// already captured by a dedicated module — a sacrament received, a
/// training completed, a certificate earned, a leadership appointment, a
/// one-off volunteer contribution. Ministries, small groups, events,
/// attendance, and giving already have their own tracking (MinistryMembership,
/// SmallGroupMembership, EventRegistration, AttendanceRecord, Contribution);
/// this model exists for everything else in a member's personal history,
/// and `GET /reports/members/:id/activity-history` merges all of them into
/// one timeline. `activityType` composes into Custom Fields exactly the way
/// VisitorActivity's does (`member_activity:{activityType}`, mirroring
/// `visitor_activity:{activityType}`) — see
/// docs/member-activities/business-analysis.md.
model MemberActivity {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  memberId          String    @map("member_id")
  member            Member    @relation(fields: [memberId], references: [id])
  activityType      String    @map("activity_type") // ConfigItem key, namespace "member_activity_type"
  activityDate      DateTime  @default(now()) @map("activity_date")
  outcome           String?
  notes             String?
  performedByUserId String?   @map("performed_by_user_id")
  performedByUser   User?     @relation("MemberActivityPerformedBy", fields: [performedByUserId], references: [id])
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, memberId])
  @@index([tenantId, activityType])
  @@map("member_activities")
}

// ----------------------------------------------------------------------------
// FINANCE
// ----------------------------------------------------------------------------

/// A recorded contribution (tithe, offering, building fund, ...) against a
/// Branch and, optionally, a Member. See docs/finance/business-analysis.md
/// for why this model has no `deletedAt`/delete endpoint: financial records
/// are corrected by voiding (isVoided/voidedAt/voidReason/voidedByUserId),
/// never edited or hard-deleted, to preserve the audit trail.
model Contribution {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  branchId         String    @map("branch_id")
  branch           Branch    @relation(fields: [branchId], references: [id])
  memberId         String?   @map("member_id")
  member           Member?   @relation(fields: [memberId], references: [id])
  contributionType String    @map("contribution_type") // ConfigItem key, namespace "contribution_type"
  amount           Decimal   @db.Decimal(14, 2)
  currency         String
  paymentMethod    String    @map("payment_method") // "cash" | "bank_transfer" | "mobile_money" | "cheque" | "other"
  receiptNumber    String?   @map("receipt_number")
  contributedAt    DateTime  @map("contributed_at")
  recordedByUserId String?   @map("recorded_by_user_id")
  recordedByUser   User?     @relation("ContributionRecordedBy", fields: [recordedByUserId], references: [id])
  notes            String?
  isVoided         Boolean   @default(false) @map("is_voided")
  voidedAt         DateTime? @map("voided_at")
  voidReason       String?   @map("void_reason")
  voidedByUserId   String?   @map("voided_by_user_id")
  voidedByUser     User?     @relation("ContributionVoidedBy", fields: [voidedByUserId], references: [id])
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, receiptNumber])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, memberId])
  @@index([tenantId, contributedAt])
  @@map("contributions")
}

// ----------------------------------------------------------------------------
// ATTENDANCE
// ----------------------------------------------------------------------------

/// A recorded attendance entry against a Branch and, optionally, a Member —
/// see docs/attendance/business-analysis.md. Unlike Contribution, this model
/// uses the Foundation module's plain "soft delete, always" rule
/// (`deletedAt`), not Finance's stricter void-only pattern: correcting a
/// head-count typo doesn't need the same audit trail a financial record does.
///
/// `memberId` null means an anonymous/bulk head-count entry (`headcount` > 1
/// allowed); `memberId` set means one individual's attendance (`headcount`
/// is always 1, enforced by the service layer, not the schema).
model AttendanceRecord {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  branchId          String    @map("branch_id")
  branch            Branch    @relation(fields: [branchId], references: [id])
  memberId          String?   @map("member_id")
  member            Member?   @relation(fields: [memberId], references: [id])
  serviceType       String    @map("service_type") // ConfigItem key, namespace "service_type"
  attendanceMethod  String?   @map("attendance_method") // ConfigItem key, namespace "attendance_method"
  headcount         Int       @default(1)
  attendedAt        DateTime  @map("attended_at")
  recordedByUserId  String?   @map("recorded_by_user_id")
  recordedByUser    User?     @relation("AttendanceRecordedBy", fields: [recordedByUserId], references: [id])
  notes             String?
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  @@unique([tenantId, branchId, memberId, serviceType, attendedAt])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, memberId])
  @@index([tenantId, attendedAt])
  @@map("attendance_records")
}

// ----------------------------------------------------------------------------
// MINISTRY & VOLUNTEER MANAGEMENT
// ----------------------------------------------------------------------------

/// A ministry (Youth, Choir, Ushering, ...) — see
/// docs/ministry/business-analysis.md. Flat, like Family (no self-reference):
/// nothing in the platform's brief calls for sub-ministry nesting the way
/// Church & Hierarchy explicitly does for branches, so this doesn't borrow
/// Branch's tree pattern. `ministryType` is a free-form ConfigItem key
/// (namespace "ministry_type"), same rule as everywhere else. `branchId` is
/// optional: a ministry may be church-wide (null) or scoped to one branch.
model Ministry {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  branchId     String?   @map("branch_id")
  branch       Branch?   @relation(fields: [branchId], references: [id])
  name         String
  ministryType String?   @map("ministry_type") // ConfigItem key, namespace "ministry_type"
  description  String?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  memberships MinistryMembership[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("ministries")
}

/// A member's volunteer assignment to a ministry. Unlike Family's
/// `headOfFamilyId`, leadership is NOT a denormalized field on `Ministry` —
/// it's just `role: "leader"` here, since (unlike a family's single head) a
/// ministry can reasonably have co-leaders with no uniqueness constraint
/// needed.
model MinistryMembership {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  ministryId String    @map("ministry_id")
  ministry   Ministry  @relation(fields: [ministryId], references: [id])
  memberId   String    @map("member_id")
  member     Member    @relation(fields: [memberId], references: [id])
  role       String    @default("member") @map("role") // "leader" | "volunteer" | "member"
  joinedAt   DateTime? @map("joined_at")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, ministryId, memberId])
  @@index([tenantId])
  @@index([tenantId, ministryId])
  @@index([tenantId, memberId])
  @@map("ministry_memberships")
}

// ----------------------------------------------------------------------------
// COMMUNICATION
// ----------------------------------------------------------------------------

/// A record of a notification sent (or attempted) through one channel — see
/// docs/communication/business-analysis.md. `recipient` is always a concrete
/// address (an email, a phone number, a push token): either supplied
/// directly, or resolved from `recipientMemberId`'s `email`/`phone` at
/// creation time, so the record stays accurate even if the member's contact
/// info later changes. Actual delivery goes through the existing
/// QueueModule/BullMQ pipeline (`backend/src/queue/`); `status` is updated
/// by `NotificationsProcessor` once the (stubbed) send attempt completes.
model Notification {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  channel          String // "email" | "sms" | "push"
  recipientMemberId String?  @map("recipient_member_id")
  recipientMember  Member?   @relation(fields: [recipientMemberId], references: [id])
  recipient        String // resolved concrete address/token
  subject          String?
  body             String
  status           String    @default("queued") // "queued" | "sent" | "failed"
  errorMessage     String?   @map("error_message")
  sentAt           DateTime? @map("sent_at")
  createdByUserId  String?   @map("created_by_user_id")
  createdByUser    User?     @relation("NotificationCreatedBy", fields: [createdByUserId], references: [id])
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, recipientMemberId])
  @@index([tenantId, status])
  @@map("notifications")
}

// ----------------------------------------------------------------------------
// CUSTOM FIELDS
// ----------------------------------------------------------------------------

/// A tenant-defined extra field on some entity type ("member",
/// "contribution", "attendance_record", "ministry", ...) — see
/// docs/custom-fields/business-analysis.md. This is the mechanism behind the
/// platform's "never assume all churches operate the same way" brief taken
/// literally: a Catholic parish can add "Confirmation Date" to its Member
/// form, a Baptist church never sees that field at all, and neither requires
/// a code change or a migration. `entityType` is a free string (not an enum)
/// so a brand-new entity type never needs a schema change here either —
/// consistent with the Foundation module's "new types belong in config, not
/// schema" rule, just applied one level up (to fields themselves, not to
/// values within a fixed field).
model CustomFieldDefinition {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  entityType String   @map("entity_type") // "member" | "contribution" | "attendance_record" | "ministry" | ...
  fieldKey   String   @map("field_key") // stable machine key, e.g. "confirmation_date"
  label      String
  fieldType  String   @map("field_type") // "text" | "richtext" | "number" | "date" | "time" | "boolean" | "select" | "radio" | "multiselect" | "email" | "phone" | "address" | "gps" | "file" | "image" | "video" | "audio" | "signature" | "lookup"
  options    Json? // for fieldType "select"/"radio"/"multiselect": [{ "key": "...", "label": "..." }, ...]
  isRequired Boolean  @default(false) @map("is_required")
  sortOrder  Int      @default(0) @map("sort_order")
  section    String? // optional grouping label so a form can be laid out in sections, e.g. "Contact Info"
  visibleToRoleNames String[] @default([]) @map("visible_to_role_names") // empty = visible to every role
  validationRules Json? @map("validation_rules") // generic: { minLength?, maxLength?, min?, max?, pattern? }
  lookupEntityType String? @map("lookup_entity_type") // only for fieldType "lookup" — which entityType this field references
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, entityType, fieldKey])
  @@index([tenantId, entityType])
  @@map("custom_field_definitions")
}

/// One entity record's value for one custom field. Deliberately a separate
/// EAV-style table rather than a `customFields Json` column bolted onto
/// every entity — a new entity type (or a brand-new module down the line)
/// needs zero schema changes to gain custom-field support, it just starts
/// passing its own `entityType` string.
model CustomFieldValue {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") // the Member.id / Contribution.id / etc. this value belongs to
  fieldKey   String   @map("field_key")
  value      Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, entityType, entityId, fieldKey])
  @@index([tenantId, entityType, entityId])
  @@map("custom_field_values")
}

// ----------------------------------------------------------------------------
// EVENTS
// ----------------------------------------------------------------------------

/// A scheduled event (conference, camp, outreach, social) — see
/// docs/events/business-analysis.md. Flat like Ministry (no self-reference)
/// and optionally branch-scoped the same way. `eventType` is a free-form
/// ConfigItem key (namespace "event_type"), same rule as everywhere else.
model Event {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  branchId    String?   @map("branch_id")
  branch      Branch?   @relation(fields: [branchId], references: [id])
  name        String
  eventType   String?   @map("event_type") // ConfigItem key, namespace "event_type"
  description String?
  location    String?
  startsAt    DateTime  @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  capacity    Int? // soft cap enforced at registration time; null = unlimited
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  registrations EventRegistration[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, startsAt])
  @@map("events")
}

/// One person's registration for an event — either a named Member, or a
/// walk-in guest captured by name/contact (mirrors the optional-FK pattern
/// `Contribution.memberId`/`AttendanceRecord.memberId` already established:
/// a guest registration is a normal, expected case, not an edge case).
model EventRegistration {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  eventId       String    @map("event_id")
  event         Event     @relation(fields: [eventId], references: [id])
  memberId      String?   @map("member_id")
  member        Member?   @relation(fields: [memberId], references: [id])
  guestName     String?   @map("guest_name") // set when memberId is omitted
  guestContact  String?   @map("guest_contact")
  status        String    @default("registered") @map("status") // "registered" | "attended" | "cancelled"
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Only named members are deduplicated — Postgres doesn't compare NULLs as
  // equal, so multiple guest (memberId = null) registrations are unaffected.
  @@unique([tenantId, eventId, memberId])
  @@index([tenantId])
  @@index([tenantId, eventId])
  @@index([tenantId, memberId])
  @@map("event_registrations")
}

// ----------------------------------------------------------------------------
// HR & PAYROLL
// ----------------------------------------------------------------------------

/// An employment record — see docs/hr-payroll/business-analysis.md. Unlike
/// Contribution/AttendanceRecord/EventRegistration (transactional records
/// that reference a person), `Staff` IS the person's HR record, so it always
/// carries its own name; `memberId` is an optional *link* to an existing
/// congregation Member (at most one active staff record per member — hence
/// `@unique`), not a substitute for one, since plenty of staff (a contracted
/// accountant, IT support) are never members at all.
model Staff {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  memberId         String?   @unique @map("member_id")
  member           Member?   @relation(fields: [memberId], references: [id])
  branchId         String?   @map("branch_id")
  branch           Branch?   @relation(fields: [branchId], references: [id])
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  position         String? // ConfigItem key, namespace "staff_position" (e.g. "senior_pastor", "accountant")
  department       String? // ConfigItem key, namespace "department"
  employmentType   String    @map("employment_type") // "full_time" | "part_time" | "contract" | "volunteer_stipend"
  employmentStatus String    @default("active") @map("employment_status") // "active" | "on_leave" | "terminated"
  hireDate         DateTime? @map("hire_date")
  terminationDate  DateTime? @map("termination_date")
  baseSalary       Decimal?  @map("base_salary") @db.Decimal(14, 2)
  salaryCurrency   String?   @map("salary_currency")
  notes            String?
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  payrollPayments PayrollPayment[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("staff")
}

/// A single payroll disbursement for one Staff record — see
/// docs/hr-payroll/business-analysis.md for why this follows Finance's
/// stricter pattern (money leaving the church) rather than Attendance's
/// plain soft-delete: `netAmount` is fixed at creation and never edited;
/// correcting a mistake is `cancel` (only while still "pending", with a
/// mandatory reason), never a field-level edit once "paid".
model PayrollPayment {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  tenant             Tenant    @relation(fields: [tenantId], references: [id])
  staffId            String    @map("staff_id")
  staff              Staff     @relation(fields: [staffId], references: [id])
  periodStart        DateTime  @map("period_start")
  periodEnd          DateTime  @map("period_end")
  grossAmount        Decimal   @map("gross_amount") @db.Decimal(14, 2)
  deductions         Decimal   @default(0) @map("deductions") @db.Decimal(14, 2)
  netAmount          Decimal   @map("net_amount") @db.Decimal(14, 2)
  currency           String
  status             String    @default("pending") // "pending" | "paid" | "cancelled"
  paidAt             DateTime? @map("paid_at")
  paidByUserId       String?   @map("paid_by_user_id")
  paidByUser         User?     @relation("PayrollPaymentPaidBy", fields: [paidByUserId], references: [id])
  cancelReason       String?   @map("cancel_reason")
  cancelledAt        DateTime? @map("cancelled_at")
  cancelledByUserId  String?   @map("cancelled_by_user_id")
  cancelledByUser    User?     @relation("PayrollPaymentCancelledBy", fields: [cancelledByUserId], references: [id])
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, staffId])
  @@index([tenantId, periodStart])
  @@map("payroll_payments")
}

// ----------------------------------------------------------------------------
// ASSET & FACILITY MANAGEMENT (Module 10)
// ----------------------------------------------------------------------------

/// A church-owned physical asset — a building, vehicle, instrument, piece of
/// equipment, land parcel, etc. `assetCategory` (a ConfigItem key in
/// namespace "asset_category") is more than a label here: the Custom Fields
/// module treats `asset:{assetCategory}` as the entityType, so each category
/// gets its own set of tenant-defined fields (a vehicle's mileage, a
/// building's floor count, ...) without a new table or migration per
/// category. See docs/asset-management/business-analysis.md.
model Asset {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  branchId        String?   @map("branch_id")
  branch          Branch?   @relation(fields: [branchId], references: [id])
  name            String
  assetCategory   String    @map("asset_category") // ConfigItem key, namespace "asset_category" — fixed after creation
  assetTag        String?   @map("asset_tag") // optional human/barcode identifier
  condition       String?   // ConfigItem key, namespace "asset_condition"
  status          String    @default("in_use") // "in_use" | "in_storage" | "under_maintenance" | "disposed" | "lost"
  location        String?
  acquisitionDate DateTime? @map("acquisition_date")
  acquisitionCost Decimal?  @map("acquisition_cost") @db.Decimal(14, 2)
  currentValue    Decimal?  @map("current_value") @db.Decimal(14, 2)
  currency        String?
  notes           String?
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  @@unique([tenantId, assetTag])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, assetCategory])
  @@map("assets")
}

// ----------------------------------------------------------------------------
// VISITOR & FOLLOW-UP MANAGEMENT (Module 11)
// ----------------------------------------------------------------------------

/// A delegation, family, choir/youth visit, conference party, or mission
/// team that arrives together — an individual `Visitor` may optionally
/// belong to one (`visitorGroupId`), or a `VisitorActivity` may be logged
/// against the whole group at once (a single "hosted the choir" entry
/// instead of one per member). `groupType` is a ConfigItem key (namespace
/// "visitor_group_type") the same way `Visitor.source` is, so a tenant adds
/// new kinds of group without a migration. See
/// docs/visitor-management/business-analysis.md.
model VisitorGroup {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  branchId         String?   @map("branch_id")
  branch           Branch?   @relation(fields: [branchId], references: [id])
  name             String
  groupType        String    @map("group_type") // ConfigItem key, namespace "visitor_group_type"
  visitDate        DateTime  @map("visit_date")
  contactName      String?   @map("contact_name")
  contactPhone     String?   @map("contact_phone")
  contactEmail     String?   @map("contact_email")
  expectedSize     Int?      @map("expected_size")
  source           String?   // ConfigItem key, namespace "visitor_source"
  assignedToUserId String?   @map("assigned_to_user_id")
  assignedToUser   User?     @relation("VisitorGroupAssignedTo", fields: [assignedToUserId], references: [id])
  status           String    @default("new") // "new" | "contacted" | "scheduled_visit" | "no_response" | "closed"
  notes            String?
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  members    Visitor[]
  activities VisitorActivity[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("visitor_groups")
}

/// A first-time (or not-yet-member) visitor — tracked from first contact
/// through follow-up to (optionally) becoming a Member. `status` is a plain
/// lifecycle field (unlike PayrollPayment's stricter pending->paid pattern)
/// since nothing here carries a financial audit-trail obligation. See
/// docs/visitor-management/business-analysis.md.
model Visitor {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  branchId         String?   @map("branch_id")
  branch           Branch?   @relation(fields: [branchId], references: [id])
  visitorGroupId   String?   @map("visitor_group_id")
  visitorGroup     VisitorGroup? @relation(fields: [visitorGroupId], references: [id])
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  phone            String?
  email            String?
  address          String?
  visitDate        DateTime  @map("visit_date")
  source           String?   // ConfigItem key, namespace "visitor_source"
  invitedByMemberId String?  @map("invited_by_member_id")
  invitedByMember  Member?   @relation("VisitorInvitedBy", fields: [invitedByMemberId], references: [id])
  assignedToUserId String?   @map("assigned_to_user_id")
  assignedToUser   User?     @relation("VisitorAssignedTo", fields: [assignedToUserId], references: [id])
  status           String    @default("new") // "new" | "contacted" | "scheduled_visit" | "joined" | "no_response" | "closed"
  convertedMemberId String?  @unique @map("converted_member_id")
  convertedMember  Member?   @relation("VisitorConvertedTo", fields: [convertedMemberId], references: [id])
  notes            String?
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  activities VisitorActivity[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, status])
  @@index([tenantId, visitorGroupId])
  @@map("visitors")
}

/// One logged, tenant-configurable activity (First Visit, Counseling, Prayer,
/// Follow-up, Evangelism, Home Visit, Baptism Class, Marriage Class,
/// Deliverance, Bible Study, Outreach, Conference, or a custom type a church
/// defines itself) against either an individual Visitor or a whole
/// VisitorGroup — exactly one of `visitorId`/`visitorGroupId` is set,
/// enforced in the service layer the same way Contribution enforces its own
/// invariants. `activityType` is a ConfigItem key (namespace
/// "visitor_activity_type"); each type gets its own Custom Fields via the
/// `visitor_activity:{activityType}` entityType composition Assets already
/// established for `asset:{assetCategory}` — no activity form is hardcoded.
model VisitorActivity {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  visitorId         String?   @map("visitor_id")
  visitor           Visitor?  @relation(fields: [visitorId], references: [id])
  visitorGroupId    String?   @map("visitor_group_id")
  visitorGroup      VisitorGroup? @relation(fields: [visitorGroupId], references: [id])
  activityType      String    @map("activity_type") // ConfigItem key, namespace "visitor_activity_type"
  activityDate      DateTime  @default(now()) @map("activity_date")
  outcome           String?
  notes             String?
  performedByUserId String?   @map("performed_by_user_id")
  performedByUser   User?     @relation("VisitorActivityPerformedBy", fields: [performedByUserId], references: [id])
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, visitorId])
  @@index([tenantId, visitorGroupId])
  @@index([tenantId, activityType])
  @@map("visitor_activities")
}

// ----------------------------------------------------------------------------
// DOCUMENT MANAGEMENT (Module 12)
// ----------------------------------------------------------------------------

/// A stored file (policy, meeting minutes, form, certificate, sermon notes,
/// legal document, ...) with metadata — unlike Asset's `file`-type custom
/// fields (one small attachment on someone else's record), a Document *is*
/// the record; `category` is a ConfigItem, not a composed Custom Fields
/// entityType, since a document has no category-specific extra fields to
/// model. See docs/document-management/business-analysis.md.
model Document {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  branchId         String?   @map("branch_id")
  branch           Branch?   @relation(fields: [branchId], references: [id])
  title            String
  description      String?
  category         String    // ConfigItem key, namespace "document_category"
  fileKey          String    @map("file_key")
  fileName         String    @map("file_name")
  fileSize         Int       @map("file_size")
  contentType      String    @map("content_type")
  uploadedByUserId String?   @map("uploaded_by_user_id")
  uploadedByUser   User?     @relation("DocumentUploadedBy", fields: [uploadedByUserId], references: [id])
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  versions DocumentVersion[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, category])
  @@map("documents")
}

/// A snapshot of a Document's file that a later `replaceFile` superseded —
/// taken *before* overwriting, so it captures what the file used to be, not
/// what it became. Append-only (no update/delete), the same "history isn't
/// rewritten" shape VisitorActivity/MemberActivity use, and the previous
/// object is never deleted from storage — see
/// docs/document-management/business-analysis.md.
model DocumentVersion {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  documentId        String   @map("document_id")
  document          Document @relation(fields: [documentId], references: [id])
  fileKey           String   @map("file_key")
  fileName          String   @map("file_name")
  fileSize          Int      @map("file_size")
  contentType       String   @map("content_type")
  replacedByUserId  String?  @map("replaced_by_user_id")
  replacedByUser    User?    @relation("DocumentVersionReplacedBy", fields: [replacedByUserId], references: [id])
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, documentId])
  @@map("document_versions")
}

// ----------------------------------------------------------------------------
// SMALL GROUPS & CHILDREN'S MINISTRY (Module 13)
// ----------------------------------------------------------------------------

/// A discipleship/fellowship group — a home group, cell group, Sunday School
/// class, youth group, or Bible study — distinct from Ministry &
/// Volunteer Management's serving teams (Module 5). Structurally it mirrors
/// `Ministry`/`MinistryMembership` closely (flat, optionally branch-scoped,
/// role-based membership), but carries scheduling, capacity, and age-range
/// fields a volunteer team has no use for. See
/// docs/small-groups/business-analysis.md.
model SmallGroup {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  branchId    String?   @map("branch_id")
  branch      Branch?   @relation(fields: [branchId], references: [id])
  name        String
  groupType   String?   @map("group_type") // ConfigItem key, namespace "small_group_type"
  description String?
  meetingDay  String?   @map("meeting_day") // "monday".."sunday" — a fixed set, not a ConfigItem
  meetingTime String?   @map("meeting_time") // "HH:mm", 24-hour
  location    String?
  capacity    Int? // soft cap enforced at membership-creation time, same pattern as Event.capacity; null = unlimited
  minAge      Int?      @map("min_age")
  maxAge      Int?      @map("max_age")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  memberships SmallGroupMembership[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("small_groups")
}

/// A member's participation in a small group. Leadership is a role value
/// ("leader"/"co_leader"/"member"), not a denormalized field — the same
/// reasoning `MinistryMembership.role` already established, since a small
/// group can reasonably have a co-leader.
model SmallGroupMembership {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  smallGroupId String    @map("small_group_id")
  smallGroup   SmallGroup @relation(fields: [smallGroupId], references: [id])
  memberId     String    @map("member_id")
  member       Member    @relation(fields: [memberId], references: [id])
  role         String    @default("member") // "leader" | "co_leader" | "member"
  joinedAt     DateTime? @map("joined_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, smallGroupId, memberId])
  @@index([tenantId])
  @@index([tenantId, smallGroupId])
  @@index([tenantId, memberId])
  @@map("small_group_memberships")
}

// ----------------------------------------------------------------------------
// AUDIT LOG
// ----------------------------------------------------------------------------
/// The tenant-wide change log. Historically written only by AuthService
/// (login/logout/MFA); `AuditService` (backend/src/audit/audit.service.ts)
/// generalizes this into shared, injectable infrastructure so any module can
/// record a mutation. `reason`/`previousValue`/`newValue` are first-class
/// columns (not folded into `metadata`) because they're queried on and
/// mandatory for the specific "important record" actions this platform
/// requires a reason for — see `@RequiresAuditReason()` and
/// docs/governance/business-analysis.md.
model AuditLog {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  userId        String?  @map("user_id")
  user          User?    @relation(fields: [userId], references: [id])
  action        String // e.g. "auth.login", "role.updated", "config.created"
  entityType    String   @map("entity_type")
  entityId      String?  @map("entity_id")
  reason        String? // mandatory-comment text for actions gated by @RequiresAuditReason()
  previousValue Json?    @map("previous_value")
  newValue      Json?    @map("new_value")
  metadata      Json?
  ipAddress     String?  @map("ip_address")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@map("audit_logs")
}

// ----------------------------------------------------------------------------
// GOVERNANCE: Approval Workflows & Deadlines (cross-cutting, reused by
// Hierarchy Requirements, Dynamic Modules, and Member Registration)
// ----------------------------------------------------------------------------

/// A tenant-defined, ordered chain of approval steps for one `entityType`
/// (e.g. "member_registration", "hierarchy_requirement_submission", or a
/// Dynamic Module's own "dynamicmodule:{moduleDefinitionId}"). Deliberately a
/// linear chain, not an arbitrary state-machine/BPMN engine — nothing in the
/// requirements this serves asks for conditional branching, only "who
/// approves this, in what order." See docs/governance/business-analysis.md.
model ApprovalWorkflow {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  entityType String   @map("entity_type")
  name       String
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  steps    ApprovalStep[]
  requests ApprovalRequest[]
  hierarchyRequirements HierarchyRequirement[]
  dynamicModuleDefinitions DynamicModuleDefinition[]

  @@unique([tenantId, entityType, name])
  @@index([tenantId, entityType])
  @@map("approval_workflows")
}

/// One step in an ApprovalWorkflow — the approver gate is either a role name
/// or a permission code (mirrors `@Roles`/`@Permissions`' own either/or
/// shape), never both, so "does this user satisfy this step" is a single
/// lookup against data the platform already assembles at login.
model ApprovalStep {
  id                     String   @id @default(uuid())
  tenantId               String   @map("tenant_id")
  tenant                 Tenant   @relation(fields: [tenantId], references: [id])
  workflowId             String   @map("workflow_id")
  workflow               ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepOrder              Int      @map("step_order")
  label                  String
  approverRoleName       String?  @map("approver_role_name")
  approverPermissionCode String?  @map("approver_permission_code")
  createdAt              DateTime @default(now()) @map("created_at")

  @@unique([workflowId, stepOrder])
  @@index([tenantId])
  @@map("approval_steps")
}

/// One concrete thing (a pending Member, a HierarchyRequirementSubmission, a
/// DynamicModuleRecord) working its way through an ApprovalWorkflow.
/// Individual approve/reject decisions are recorded through `AuditService`
/// (action `approval.approved`/`approval.rejected`, entityType
/// `approval_request`, `reason` mandatory) rather than a second dedicated
/// table — the audit log is already the source of truth for "who decided
/// what, when, why."
model ApprovalRequest {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  workflowId       String   @map("workflow_id")
  workflow         ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  entityType       String   @map("entity_type")
  entityId         String   @map("entity_id")
  currentStepOrder Int      @default(1) @map("current_step_order")
  status           String   @default("pending") @map("status") // "pending" | "approved" | "rejected"
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, entityType, entityId])
  @@index([tenantId, workflowId])
  @@index([tenantId, status])
  @@map("approval_requests")
}

/// A configurable submission deadline against any (`entityType`, `entityId`)
/// pair — a HierarchyRequirementSubmission, a Dynamic Module record, or any
/// future "this has to happen by X" need. `open -> locked` happens
/// automatically once `dueAt` passes (checked lazily on read, see
/// `DeadlinesService.effectiveStatus` — no cron needed just to flip a
/// status); `locked -> open` only via the permissioned `extend` action
/// (reason mandatory); `* -> closed` via the permissioned `close` action;
/// `closed` is immutable except via the permissioned `reopen` action. The
/// same "dedicated action per real side effect" shape as
/// `Visitor.convertToMember`/`Member.transfer`.
model Deadline {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  entityType       String    @map("entity_type")
  entityId         String    @map("entity_id")
  dueAt            DateTime  @map("due_at")
  status           String    @default("open") @map("status") // "open" | "locked" | "closed" — see effectiveStatus for the open->locked transition
  extendedByUserId String?   @map("extended_by_user_id")
  extendedByUser   User?     @relation("DeadlineExtendedBy", fields: [extendedByUserId], references: [id])
  extensionReason  String?   @map("extension_reason")
  closedAt         DateTime? @map("closed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, entityType, entityId])
  @@index([tenantId, status])
  @@index([tenantId, dueAt])
  @@map("deadlines")
}

// ----------------------------------------------------------------------------
// HIERARCHY REQUIREMENTS (Module 16) — a parent Branch's requirements for its
// immediate child Branches
// ----------------------------------------------------------------------------

/// A requirement one organizational level defines for the level directly
/// beneath it — e.g. a Diocese requires every District to submit a monthly
/// activity report. `parentBranchType`/`childBranchType` are `branch_type`
/// `ConfigItem` keys (the same ones `Branch.branchType` already uses), so
/// "Diocese requires this of District" needs no new hierarchy concept beyond
/// this one table — see docs/hierarchy-requirements/business-analysis.md.
/// `frequency`/`dueDayOfPeriod` are informational/display fields today (an
/// admin sees "this recurs monthly"); the concrete due date for each cycle
/// is set explicitly on the `HierarchyRequirementSubmission` via `Deadline`,
/// not computed automatically — see the module's Out of Scope section for
/// why automatic period-end date math is deferred.
model HierarchyRequirement {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  tenant             Tenant    @relation(fields: [tenantId], references: [id])
  parentBranchType   String    @map("parent_branch_type")
  childBranchType    String    @map("child_branch_type")
  kind               String // "report" | "document" | "form" | "activity" | "compliance"
  label              String
  description        String?
  frequency          String    @default("once") @map("frequency") // "once" | "monthly" | "quarterly" | "annually" — informational
  dueDayOfPeriod     Int?      @map("due_day_of_period") // informational, e.g. "the 5th of every month"
  approvalWorkflowId String?   @map("approval_workflow_id")
  approvalWorkflow   ApprovalWorkflow? @relation(fields: [approvalWorkflowId], references: [id])
  notifyRoleNames    String[]  @default([]) @map("notify_role_names")
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  submissions HierarchyRequirementSubmission[]

  @@index([tenantId])
  @@index([tenantId, parentBranchType, childBranchType])
  @@map("hierarchy_requirements")
}

/// One child Branch's actual submission against a `HierarchyRequirement` for
/// one cycle (`periodLabel`, e.g. `"2026-07"` for a monthly requirement, or
/// `""` for a one-off requirement — kept a concrete empty string rather than
/// null so the compound unique constraint below actually enforces
/// uniqueness: Postgres treats every NULL as distinct, so a nullable column
/// in a unique index silently allows duplicate rows). Its deadline and
/// approval chain are *not* stored here as FKs — they're resolved by key
/// (`entityType: "hierarchy_requirement_submission"`, `entityId: this row's
/// id`) against Phase 0's generic `Deadline`/`ApprovalWorkflow` tables,
/// exactly the composition trick Custom Fields already established for
/// per-category fields. `attachedDocumentIds` is a loose array of
/// `Document.id`s (uploaded through the existing Documents module) rather
/// than a join table — a submission rarely has more than a handful of
/// attachments and doesn't need its own relation semantics.
model HierarchyRequirementSubmission {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  requirementId     String    @map("requirement_id")
  requirement       HierarchyRequirement @relation(fields: [requirementId], references: [id])
  branchId          String    @map("branch_id")
  branch            Branch    @relation(fields: [branchId], references: [id])
  periodLabel       String    @default("") @map("period_label")
  status            String    @default("pending") @map("status") // "pending" | "submitted" | "approved" | "rejected"
  attachedDocumentIds String[] @default([]) @map("attached_document_ids")
  submittedByUserId String?   @map("submitted_by_user_id")
  submittedByUser   User?     @relation(fields: [submittedByUserId], references: [id])
  submittedAt       DateTime? @map("submitted_at")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, requirementId, branchId, periodLabel])
  @@index([tenantId])
  @@index([tenantId, requirementId])
  @@index([tenantId, branchId])
  @@map("hierarchy_requirement_submissions")
}

// ----------------------------------------------------------------------------
// DYNAMIC MODULES: admin-defined modules, no code change required
// ----------------------------------------------------------------------------

/// An admin-defined functional module — its own record type, with its own
/// statuses, optionally attachable to an existing entity (Branch, Ministry,
/// Member, another Dynamic Module's records, ...) or standalone (in which
/// case its own records serve as a brand-new entity type other things attach
/// to — see design decision in docs/dynamic-modules/business-analysis.md).
/// Custom fields on this module's records reuse `CustomFieldDefinition`/
/// `CustomFieldValue` with `entityType = "dynamicmodule:{this.id}"`, the same
/// composition trick already proven for Assets/Visitor Activities/Member
/// Activities — no new field-storage mechanism is built here.
model DynamicModuleDefinition {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  key        String // stable machine key, e.g. "committee-requests"
  label      String
  description String?
  icon       String? // an icon name the frontend maps to a lucide-react icon
  /// Which existing entityType strings a record of this module may attach
  /// to — informational, for the builder UI's dropdown; not enforced at the
  /// database level since attachment is a loose (entityType, entityId) pair
  /// like every other composed entityType in this platform.
  attachableToEntityTypes String[] @default([]) @map("attachable_to_entity_types")
  /// Tenant-defined, ordered list of status labels a record may hold. The
  /// first entry is the default status a new record starts in.
  statuses   String[] @default(["open", "closed"])
  approvalWorkflowId String? @map("approval_workflow_id")
  approvalWorkflow   ApprovalWorkflow? @relation(fields: [approvalWorkflowId], references: [id])
  showInNav  Boolean  @default(false) @map("show_in_nav")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  records DynamicModuleRecord[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("dynamic_module_definitions")
}

/// One record of an admin-defined module. `attachedToEntityType`/
/// `attachedToEntityId` are both null for a standalone record (the module
/// itself acting as a brand-new entity type); both set when the record
/// attaches to something else (a Branch, a Ministry, another Dynamic
/// Module's record via `"dynamicmodule:{otherDefinitionId}"`, ...).
/// `branchId` is separate from the attachment pair — set when the record's
/// own organizational scope matters for Phase 4's visibility roll-up,
/// regardless of what it's attached to.
model DynamicModuleRecord {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  moduleDefinitionId String @map("module_definition_id")
  moduleDefinition DynamicModuleDefinition @relation(fields: [moduleDefinitionId], references: [id])
  attachedToEntityType String? @map("attached_to_entity_type")
  attachedToEntityId   String? @map("attached_to_entity_id")
  status           String
  title            String?
  branchId         String?  @map("branch_id")
  branch           Branch?  @relation(fields: [branchId], references: [id])
  createdByUserId  String?  @map("created_by_user_id")
  createdByUser    User?    @relation("DynamicModuleRecordCreatedBy", fields: [createdByUserId], references: [id])
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  statusHistory DynamicModuleRecordStatusHistory[]

  @@index([tenantId])
  @@index([tenantId, moduleDefinitionId])
  @@index([tenantId, attachedToEntityType, attachedToEntityId])
  @@map("dynamic_module_records")
}

/// Append-only status-change history for a `DynamicModuleRecord` — feeds
/// `AuditService` too, but this table exists separately (unlike an
/// `ApprovalRequest` decision, which lives only in `AuditLog`) because a
/// record's status history is a first-class thing this module's own UI
/// displays as a timeline, not just an audit trail.
model DynamicModuleRecordStatusHistory {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  recordId       String   @map("record_id")
  record         DynamicModuleRecord @relation(fields: [recordId], references: [id])
  fromStatus     String?  @map("from_status")
  toStatus       String   @map("to_status")
  changedByUserId String? @map("changed_by_user_id")
  changedByUser  User?    @relation("DynamicModuleRecordStatusChangedBy", fields: [changedByUserId], references: [id])
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([tenantId, recordId])
  @@map("dynamic_module_record_status_history")
}

/// Generalizes `MinistryMembership`/`SmallGroupMembership`'s already-correct
/// shape — a `Member` attaches to an entity with a role, never duplicated as
/// a new `Member` row — for Dynamic Module entities specifically (a
/// standalone module's records acting as a new entity type, e.g.
/// "Fellowship"). The two existing hand-rolled membership tables are left
/// exactly as they are; this is not a migration target for them, it only
/// covers entities that have no dedicated membership table of their own.
/// `attachedToEntityType` is conventionally `"dynamicmodule:{moduleDefinitionId}"`
/// (the same string other records use to attach to a Dynamic Module's
/// records), but is not restricted to that at the schema level.
model EntityMembership {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  attachedToEntityType String @map("attached_to_entity_type")
  attachedToEntityId   String @map("attached_to_entity_id")
  memberId     String    @map("member_id")
  member       Member    @relation(fields: [memberId], references: [id])
  role         String    @default("member")
  joinedAt     DateTime? @map("joined_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, attachedToEntityType, attachedToEntityId, memberId])
  @@index([tenantId])
  @@index([tenantId, attachedToEntityType, attachedToEntityId])
  @@index([tenantId, memberId])
  @@map("entity_memberships")
}
