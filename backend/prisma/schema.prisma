// ============================================================================
// UCMS - Foundation Module Prisma Schema
// Multi-tenancy, Auth (RBAC/PBAC), and the Configuration Engine
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// TENANT
// ----------------------------------------------------------------------------
model Tenant {
  id               String    @id @default(uuid())
  name             String
  slug             String    @unique
  customDomain     String?   @unique @map("custom_domain")
  logoUrl          String?   @map("logo_url")
  themeConfig      Json?     @map("theme_config")
  currency         String    @default("RWF")
  language         String    @default("en")
  timezone         String    @default("Africa/Kigali")
  subscriptionPlan String    @default("free") @map("subscription_plan")
  isActive         Boolean   @default(true) @map("is_active")
  onboardedAt      DateTime? @map("onboarded_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  users          User[]
  roles          Role[]
  configItems    ConfigItem[]
  featureToggles FeatureToggle[]
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]
  branches           Branch[]
  members            Member[]
  families           Family[]
  contributions      Contribution[]
  attendanceRecords  AttendanceRecord[]
  ministries         Ministry[]
  ministryMemberships MinistryMembership[]
  notifications      Notification[]
  customFieldDefinitions CustomFieldDefinition[]
  customFieldValues      CustomFieldValue[]
  events                 Event[]
  eventRegistrations     EventRegistration[]
  staff                  Staff[]
  payrollPayments        PayrollPayment[]
  assets                 Asset[]

  @@map("tenants")
}

// ----------------------------------------------------------------------------
// USERS
// ----------------------------------------------------------------------------
model User {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  email        String
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  isActive     Boolean   @default(true) @map("is_active")
  mfaEnabled   Boolean   @default(false) @map("mfa_enabled")
  mfaSecret    String?   @map("mfa_secret")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  userRoles             UserRole[]
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]
  recordedContributions Contribution[]     @relation("ContributionRecordedBy")
  voidedContributions   Contribution[]     @relation("ContributionVoidedBy")
  recordedAttendance    AttendanceRecord[] @relation("AttendanceRecordedBy")
  createdNotifications  Notification[]     @relation("NotificationCreatedBy")
  paidPayrollPayments     PayrollPayment[] @relation("PayrollPaymentPaidBy")
  cancelledPayrollPayments PayrollPayment[] @relation("PayrollPaymentCancelledBy")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ----------------------------------------------------------------------------
// ROLES / PERMISSIONS (RBAC + PBAC)
// ----------------------------------------------------------------------------
model Role {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

/// Global, platform-versioned catalog of permission codes.
/// New modules add rows here via migration; tenants only ever attach
/// existing codes to their own roles.
model Permission {
  id          String  @id @default(uuid())
  code        String  @unique // e.g. "finance.contribution.create"
  module      String // e.g. "finance"
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String     @map("role_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ----------------------------------------------------------------------------
// AUTH SESSIONS
// ----------------------------------------------------------------------------
model RefreshToken {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id])
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  replacedBy String?   @map("replaced_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([tenantId])
  @@map("refresh_tokens")
}

// ----------------------------------------------------------------------------
// CONFIGURATION ENGINE (generic — powers ministries, contribution types,
// ceremony names, membership categories, etc. for every future module)
// ----------------------------------------------------------------------------
model ConfigItem {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  namespace String // "ministry" | "contribution_type" | "ceremony" | "membership_category" | ...
  key       String // stable machine key, e.g. "tithe"
  label     String // human display label, e.g. "Tithe"
  value     Json // arbitrary shape, owned by the consuming module
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, namespace, key])
  @@index([tenantId, namespace])
  @@map("config_items")
}

model FeatureToggle {
  id         String  @id @default(uuid())
  tenantId   String  @map("tenant_id")
  tenant     Tenant  @relation(fields: [tenantId], references: [id])
  featureKey String  @map("feature_key")
  isEnabled  Boolean @default(false) @map("is_enabled")

  @@unique([tenantId, featureKey])
  @@map("feature_toggles")
}

// ----------------------------------------------------------------------------
// CHURCH & HIERARCHY MANAGEMENT
// ----------------------------------------------------------------------------

/// A tenant's organizational hierarchy, modeled as a single self-referencing
/// tree of arbitrary depth so it can represent anything from a Catholic
/// diocese -> parish -> branch structure to a flat, single-location
/// independent church. Denomination-specific labels ("Diocese", "Parish",
/// "District", "Cell") are NOT modeled as an enum here — `branchType` is a
/// free-form key that a tenant defines via the Configuration Engine
/// (ConfigItem, namespace "branch_type"), consistent with the Foundation
/// module's rule that new "types" belong in the config engine, not a schema
/// change.
model Branch {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  parentBranchId String?   @map("parent_branch_id")
  parentBranch   Branch?   @relation("BranchHierarchy", fields: [parentBranchId], references: [id])
  childBranches  Branch[]  @relation("BranchHierarchy")
  name           String
  branchType     String?   @map("branch_type") // e.g. "parish", "district" — a ConfigItem key in namespace "branch_type"
  code           String?
  address        String?
  isHeadquarters Boolean   @default(false) @map("is_headquarters")
  isActive       Boolean   @default(true) @map("is_active")
  sortOrder      Int       @default(0) @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  members           Member[]
  contributions     Contribution[]
  attendanceRecords AttendanceRecord[]
  ministries        Ministry[]
  events            Event[]
  staff             Staff[]
  assets            Asset[]

  @@index([tenantId])
  @@index([tenantId, parentBranchId])
  @@map("branches")
}

// ----------------------------------------------------------------------------
// MEMBER & FAMILY MANAGEMENT
// ----------------------------------------------------------------------------

/// A household grouping members together. Flat (no self-reference, unlike
/// Branch) — a family is a label members point to, not a hierarchy. See
/// docs/member-management/business-analysis.md for why deactivating a family
/// intentionally does NOT cascade to its members (contrast with Branch).
model Family {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  name           String
  address        String?
  phone          String?
  headOfFamilyId String?   @unique @map("head_of_family_id")
  headOfFamily   Member?   @relation("FamilyHead", fields: [headOfFamilyId], references: [id])
  notes          String?
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  members Member[] @relation("FamilyMembers")

  @@index([tenantId])
  @@map("families")
}

/// A person's membership profile, attached to exactly one Branch (Module 1)
/// and optionally grouped into a Family. `membershipCategory` is a free-form
/// ConfigItem key (namespace "membership_category") per the Foundation
/// module's "new types belong in the Configuration Engine" rule;
/// `membershipStatus` is a small fixed lifecycle enum instead, since later
/// modules (Attendance, Finance) reason structurally about it.
model Member {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  tenant             Tenant    @relation(fields: [tenantId], references: [id])
  branchId           String    @map("branch_id")
  branch             Branch    @relation(fields: [branchId], references: [id])
  familyId           String?   @map("family_id")
  family             Family?   @relation("FamilyMembers", fields: [familyId], references: [id])
  familyRole         String?   @map("family_role") // "head" | "spouse" | "child" | "dependent" | "other"
  membershipNumber   String?   @map("membership_number")
  firstName          String    @map("first_name")
  lastName           String    @map("last_name")
  gender             String?
  dateOfBirth        DateTime? @map("date_of_birth")
  phone              String?
  email              String?
  address            String?
  maritalStatus      String?   @map("marital_status")
  membershipCategory String?   @map("membership_category") // ConfigItem key, namespace "membership_category"
  membershipStatus   String    @default("active") @map("membership_status") // "active" | "inactive" | "transferred" | "deceased"
  joinedAt           DateTime? @map("joined_at")
  baptismDate        DateTime? @map("baptism_date")
  photoUrl           String?   @map("photo_url")
  notes              String?
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  headOfFamilyFor     Family?              @relation("FamilyHead")
  contributions       Contribution[]
  attendanceRecords   AttendanceRecord[]
  ministryMemberships MinistryMembership[]
  notifications       Notification[]
  eventRegistrations  EventRegistration[]
  staffRecord         Staff?

  @@unique([tenantId, membershipNumber])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, familyId])
  @@map("members")
}

// ----------------------------------------------------------------------------
// FINANCE
// ----------------------------------------------------------------------------

/// A recorded contribution (tithe, offering, building fund, ...) against a
/// Branch and, optionally, a Member. See docs/finance/business-analysis.md
/// for why this model has no `deletedAt`/delete endpoint: financial records
/// are corrected by voiding (isVoided/voidedAt/voidReason/voidedByUserId),
/// never edited or hard-deleted, to preserve the audit trail.
model Contribution {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  branchId         String    @map("branch_id")
  branch           Branch    @relation(fields: [branchId], references: [id])
  memberId         String?   @map("member_id")
  member           Member?   @relation(fields: [memberId], references: [id])
  contributionType String    @map("contribution_type") // ConfigItem key, namespace "contribution_type"
  amount           Decimal   @db.Decimal(14, 2)
  currency         String
  paymentMethod    String    @map("payment_method") // "cash" | "bank_transfer" | "mobile_money" | "cheque" | "other"
  receiptNumber    String?   @map("receipt_number")
  contributedAt    DateTime  @map("contributed_at")
  recordedByUserId String?   @map("recorded_by_user_id")
  recordedByUser   User?     @relation("ContributionRecordedBy", fields: [recordedByUserId], references: [id])
  notes            String?
  isVoided         Boolean   @default(false) @map("is_voided")
  voidedAt         DateTime? @map("voided_at")
  voidReason       String?   @map("void_reason")
  voidedByUserId   String?   @map("voided_by_user_id")
  voidedByUser     User?     @relation("ContributionVoidedBy", fields: [voidedByUserId], references: [id])
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, receiptNumber])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, memberId])
  @@index([tenantId, contributedAt])
  @@map("contributions")
}

// ----------------------------------------------------------------------------
// ATTENDANCE
// ----------------------------------------------------------------------------

/// A recorded attendance entry against a Branch and, optionally, a Member —
/// see docs/attendance/business-analysis.md. Unlike Contribution, this model
/// uses the Foundation module's plain "soft delete, always" rule
/// (`deletedAt`), not Finance's stricter void-only pattern: correcting a
/// head-count typo doesn't need the same audit trail a financial record does.
///
/// `memberId` null means an anonymous/bulk head-count entry (`headcount` > 1
/// allowed); `memberId` set means one individual's attendance (`headcount`
/// is always 1, enforced by the service layer, not the schema).
model AttendanceRecord {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  branchId          String    @map("branch_id")
  branch            Branch    @relation(fields: [branchId], references: [id])
  memberId          String?   @map("member_id")
  member            Member?   @relation(fields: [memberId], references: [id])
  serviceType       String    @map("service_type") // ConfigItem key, namespace "service_type"
  attendanceMethod  String?   @map("attendance_method") // ConfigItem key, namespace "attendance_method"
  headcount         Int       @default(1)
  attendedAt        DateTime  @map("attended_at")
  recordedByUserId  String?   @map("recorded_by_user_id")
  recordedByUser    User?     @relation("AttendanceRecordedBy", fields: [recordedByUserId], references: [id])
  notes             String?
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  @@unique([tenantId, branchId, memberId, serviceType, attendedAt])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, memberId])
  @@index([tenantId, attendedAt])
  @@map("attendance_records")
}

// ----------------------------------------------------------------------------
// MINISTRY & VOLUNTEER MANAGEMENT
// ----------------------------------------------------------------------------

/// A ministry (Youth, Choir, Ushering, ...) — see
/// docs/ministry/business-analysis.md. Flat, like Family (no self-reference):
/// nothing in the platform's brief calls for sub-ministry nesting the way
/// Church & Hierarchy explicitly does for branches, so this doesn't borrow
/// Branch's tree pattern. `ministryType` is a free-form ConfigItem key
/// (namespace "ministry_type"), same rule as everywhere else. `branchId` is
/// optional: a ministry may be church-wide (null) or scoped to one branch.
model Ministry {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  branchId     String?   @map("branch_id")
  branch       Branch?   @relation(fields: [branchId], references: [id])
  name         String
  ministryType String?   @map("ministry_type") // ConfigItem key, namespace "ministry_type"
  description  String?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  memberships MinistryMembership[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("ministries")
}

/// A member's volunteer assignment to a ministry. Unlike Family's
/// `headOfFamilyId`, leadership is NOT a denormalized field on `Ministry` —
/// it's just `role: "leader"` here, since (unlike a family's single head) a
/// ministry can reasonably have co-leaders with no uniqueness constraint
/// needed.
model MinistryMembership {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  ministryId String    @map("ministry_id")
  ministry   Ministry  @relation(fields: [ministryId], references: [id])
  memberId   String    @map("member_id")
  member     Member    @relation(fields: [memberId], references: [id])
  role       String    @default("member") @map("role") // "leader" | "volunteer" | "member"
  joinedAt   DateTime? @map("joined_at")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([tenantId, ministryId, memberId])
  @@index([tenantId])
  @@index([tenantId, ministryId])
  @@index([tenantId, memberId])
  @@map("ministry_memberships")
}

// ----------------------------------------------------------------------------
// COMMUNICATION
// ----------------------------------------------------------------------------

/// A record of a notification sent (or attempted) through one channel — see
/// docs/communication/business-analysis.md. `recipient` is always a concrete
/// address (an email, a phone number, a push token): either supplied
/// directly, or resolved from `recipientMemberId`'s `email`/`phone` at
/// creation time, so the record stays accurate even if the member's contact
/// info later changes. Actual delivery goes through the existing
/// QueueModule/BullMQ pipeline (`backend/src/queue/`); `status` is updated
/// by `NotificationsProcessor` once the (stubbed) send attempt completes.
model Notification {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  channel          String // "email" | "sms" | "push"
  recipientMemberId String?  @map("recipient_member_id")
  recipientMember  Member?   @relation(fields: [recipientMemberId], references: [id])
  recipient        String // resolved concrete address/token
  subject          String?
  body             String
  status           String    @default("queued") // "queued" | "sent" | "failed"
  errorMessage     String?   @map("error_message")
  sentAt           DateTime? @map("sent_at")
  createdByUserId  String?   @map("created_by_user_id")
  createdByUser    User?     @relation("NotificationCreatedBy", fields: [createdByUserId], references: [id])
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, recipientMemberId])
  @@index([tenantId, status])
  @@map("notifications")
}

// ----------------------------------------------------------------------------
// CUSTOM FIELDS
// ----------------------------------------------------------------------------

/// A tenant-defined extra field on some entity type ("member",
/// "contribution", "attendance_record", "ministry", ...) — see
/// docs/custom-fields/business-analysis.md. This is the mechanism behind the
/// platform's "never assume all churches operate the same way" brief taken
/// literally: a Catholic parish can add "Confirmation Date" to its Member
/// form, a Baptist church never sees that field at all, and neither requires
/// a code change or a migration. `entityType` is a free string (not an enum)
/// so a brand-new entity type never needs a schema change here either —
/// consistent with the Foundation module's "new types belong in config, not
/// schema" rule, just applied one level up (to fields themselves, not to
/// values within a fixed field).
model CustomFieldDefinition {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  entityType String   @map("entity_type") // "member" | "contribution" | "attendance_record" | "ministry" | ...
  fieldKey   String   @map("field_key") // stable machine key, e.g. "confirmation_date"
  label      String
  fieldType  String   @map("field_type") // "text" | "number" | "date" | "boolean" | "select"
  options    Json? // for fieldType "select": [{ "key": "...", "label": "..." }, ...]
  isRequired Boolean  @default(false) @map("is_required")
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, entityType, fieldKey])
  @@index([tenantId, entityType])
  @@map("custom_field_definitions")
}

/// One entity record's value for one custom field. Deliberately a separate
/// EAV-style table rather than a `customFields Json` column bolted onto
/// every entity — a new entity type (or a brand-new module down the line)
/// needs zero schema changes to gain custom-field support, it just starts
/// passing its own `entityType` string.
model CustomFieldValue {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") // the Member.id / Contribution.id / etc. this value belongs to
  fieldKey   String   @map("field_key")
  value      Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, entityType, entityId, fieldKey])
  @@index([tenantId, entityType, entityId])
  @@map("custom_field_values")
}

// ----------------------------------------------------------------------------
// EVENTS
// ----------------------------------------------------------------------------

/// A scheduled event (conference, camp, outreach, social) — see
/// docs/events/business-analysis.md. Flat like Ministry (no self-reference)
/// and optionally branch-scoped the same way. `eventType` is a free-form
/// ConfigItem key (namespace "event_type"), same rule as everywhere else.
model Event {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  branchId    String?   @map("branch_id")
  branch      Branch?   @relation(fields: [branchId], references: [id])
  name        String
  eventType   String?   @map("event_type") // ConfigItem key, namespace "event_type"
  description String?
  location    String?
  startsAt    DateTime  @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  capacity    Int? // soft cap enforced at registration time; null = unlimited
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  registrations EventRegistration[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, startsAt])
  @@map("events")
}

/// One person's registration for an event — either a named Member, or a
/// walk-in guest captured by name/contact (mirrors the optional-FK pattern
/// `Contribution.memberId`/`AttendanceRecord.memberId` already established:
/// a guest registration is a normal, expected case, not an edge case).
model EventRegistration {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  eventId       String    @map("event_id")
  event         Event     @relation(fields: [eventId], references: [id])
  memberId      String?   @map("member_id")
  member        Member?   @relation(fields: [memberId], references: [id])
  guestName     String?   @map("guest_name") // set when memberId is omitted
  guestContact  String?   @map("guest_contact")
  status        String    @default("registered") @map("status") // "registered" | "attended" | "cancelled"
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Only named members are deduplicated — Postgres doesn't compare NULLs as
  // equal, so multiple guest (memberId = null) registrations are unaffected.
  @@unique([tenantId, eventId, memberId])
  @@index([tenantId])
  @@index([tenantId, eventId])
  @@index([tenantId, memberId])
  @@map("event_registrations")
}

// ----------------------------------------------------------------------------
// HR & PAYROLL
// ----------------------------------------------------------------------------

/// An employment record — see docs/hr-payroll/business-analysis.md. Unlike
/// Contribution/AttendanceRecord/EventRegistration (transactional records
/// that reference a person), `Staff` IS the person's HR record, so it always
/// carries its own name; `memberId` is an optional *link* to an existing
/// congregation Member (at most one active staff record per member — hence
/// `@unique`), not a substitute for one, since plenty of staff (a contracted
/// accountant, IT support) are never members at all.
model Staff {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  memberId         String?   @unique @map("member_id")
  member           Member?   @relation(fields: [memberId], references: [id])
  branchId         String?   @map("branch_id")
  branch           Branch?   @relation(fields: [branchId], references: [id])
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  position         String? // ConfigItem key, namespace "staff_position" (e.g. "senior_pastor", "accountant")
  department       String? // ConfigItem key, namespace "department"
  employmentType   String    @map("employment_type") // "full_time" | "part_time" | "contract" | "volunteer_stipend"
  employmentStatus String    @default("active") @map("employment_status") // "active" | "on_leave" | "terminated"
  hireDate         DateTime? @map("hire_date")
  terminationDate  DateTime? @map("termination_date")
  baseSalary       Decimal?  @map("base_salary") @db.Decimal(14, 2)
  salaryCurrency   String?   @map("salary_currency")
  notes            String?
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  payrollPayments PayrollPayment[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("staff")
}

/// A single payroll disbursement for one Staff record — see
/// docs/hr-payroll/business-analysis.md for why this follows Finance's
/// stricter pattern (money leaving the church) rather than Attendance's
/// plain soft-delete: `netAmount` is fixed at creation and never edited;
/// correcting a mistake is `cancel` (only while still "pending", with a
/// mandatory reason), never a field-level edit once "paid".
model PayrollPayment {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  tenant             Tenant    @relation(fields: [tenantId], references: [id])
  staffId            String    @map("staff_id")
  staff              Staff     @relation(fields: [staffId], references: [id])
  periodStart        DateTime  @map("period_start")
  periodEnd          DateTime  @map("period_end")
  grossAmount        Decimal   @map("gross_amount") @db.Decimal(14, 2)
  deductions         Decimal   @default(0) @map("deductions") @db.Decimal(14, 2)
  netAmount          Decimal   @map("net_amount") @db.Decimal(14, 2)
  currency           String
  status             String    @default("pending") // "pending" | "paid" | "cancelled"
  paidAt             DateTime? @map("paid_at")
  paidByUserId       String?   @map("paid_by_user_id")
  paidByUser         User?     @relation("PayrollPaymentPaidBy", fields: [paidByUserId], references: [id])
  cancelReason       String?   @map("cancel_reason")
  cancelledAt        DateTime? @map("cancelled_at")
  cancelledByUserId  String?   @map("cancelled_by_user_id")
  cancelledByUser    User?     @relation("PayrollPaymentCancelledBy", fields: [cancelledByUserId], references: [id])
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, staffId])
  @@index([tenantId, periodStart])
  @@map("payroll_payments")
}

// ----------------------------------------------------------------------------
// ASSET & FACILITY MANAGEMENT (Module 10)
// ----------------------------------------------------------------------------

/// A church-owned physical asset — a building, vehicle, instrument, piece of
/// equipment, land parcel, etc. `assetCategory` (a ConfigItem key in
/// namespace "asset_category") is more than a label here: the Custom Fields
/// module treats `asset:{assetCategory}` as the entityType, so each category
/// gets its own set of tenant-defined fields (a vehicle's mileage, a
/// building's floor count, ...) without a new table or migration per
/// category. See docs/asset-management/business-analysis.md.
model Asset {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  branchId        String?   @map("branch_id")
  branch          Branch?   @relation(fields: [branchId], references: [id])
  name            String
  assetCategory   String    @map("asset_category") // ConfigItem key, namespace "asset_category" — fixed after creation
  assetTag        String?   @map("asset_tag") // optional human/barcode identifier
  condition       String?   // ConfigItem key, namespace "asset_condition"
  status          String    @default("in_use") // "in_use" | "in_storage" | "under_maintenance" | "disposed" | "lost"
  location        String?
  acquisitionDate DateTime? @map("acquisition_date")
  acquisitionCost Decimal?  @map("acquisition_cost") @db.Decimal(14, 2)
  currentValue    Decimal?  @map("current_value") @db.Decimal(14, 2)
  currency        String?
  notes           String?
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  @@unique([tenantId, assetTag])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, assetCategory])
  @@map("assets")
}

// ----------------------------------------------------------------------------
// AUDIT LOG
// ----------------------------------------------------------------------------
model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id])
  action     String // e.g. "auth.login", "role.updated", "config.created"
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
